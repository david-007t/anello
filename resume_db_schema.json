{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Master Resume Database",
  "description": "Structured resume database for David Osei-Tutu — used by tailor.py to select and rewrite bullets per job posting",
  "type": "object",
  "properties": {
    "identity": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "phone": { "type": "string" },
        "linkedin": { "type": "string" },
        "location": { "type": "string" },
        "current_title": { "type": "string" }
      },
      "required": ["name", "email"]
    },
    "experience": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string", "description": "Stable slug for cross-referencing (e.g. 'nutanix-de2')" },
          "role": { "type": "string" },
          "company": { "type": "string" },
          "start_date": { "type": "string", "format": "date", "description": "ISO 8601 date (YYYY-MM-DD)" },
          "end_date": { "type": ["string", "null"], "description": "null means current role" },
          "role_types": {
            "type": "array",
            "items": { "type": "string", "enum": ["data-eng", "pm", "tpm", "ops-mgr", "ml-eng", "analytics", "swe", "founder"] }
          },
          "seniority": {
            "type": "array",
            "items": { "type": "string", "enum": ["ic", "manager", "senior", "lead"] }
          },
          "industry": {
            "type": "array",
            "items": { "type": "string" }
          },
          "skills": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Skills used in this role — references skills[].name"
          },
          "bullets": {
            "type": "array",
            "items": {
              "type": "object",
              "properties": {
                "text": { "type": "string", "description": "The resume bullet as written" },
                "impact_metric": { "type": ["string", "null"], "description": "Quantified result if available (e.g. '22% runtime reduction')" },
                "impact_type": { "type": "string", "enum": ["quantified", "qualitative"] },
                "tags": {
                  "type": "array",
                  "items": { "type": "string" },
                  "description": "Searchable tags for matching to job descriptions"
                }
              },
              "required": ["text", "impact_type", "tags"]
            }
          }
        },
        "required": ["id", "role", "company", "start_date", "bullets", "role_types"]
      }
    },
    "skills": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "proficiency": { "type": "string", "enum": ["expert", "proficient", "familiar"] },
          "context": { "type": "string", "description": "One-liner on where/how this skill was used" },
          "tags": {
            "type": "array",
            "items": { "type": "string" },
            "description": "Skill category tags for grouping"
          }
        },
        "required": ["name", "proficiency", "tags"]
      }
    },
    "projects": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "outcome": { "type": "string" },
          "skills": { "type": "array", "items": { "type": "string" } },
          "role_types": {
            "type": "array",
            "items": { "type": "string", "enum": ["data-eng", "pm", "tpm", "ops-mgr", "ml-eng", "analytics", "swe", "founder"] }
          },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["id", "name", "description", "outcome"]
      }
    },
    "education": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "institution": { "type": "string" },
          "degree": { "type": "string" },
          "field": { "type": "string" },
          "graduation_date": { "type": "string", "format": "date" },
          "minors": { "type": "array", "items": { "type": "string" } },
          "gpa": { "type": ["number", "null"] },
          "honors": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["institution", "degree", "field", "graduation_date"]
      }
    },
    "awards": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "name": { "type": "string" },
          "issuer": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "description": { "type": "string" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["name", "issuer", "date"]
      }
    },
    "publications": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "title": { "type": "string" },
          "venue": { "type": "string" },
          "date": { "type": "string", "format": "date" },
          "authors": { "type": "array", "items": { "type": "string" } },
          "url": { "type": ["string", "null"], "format": "uri" },
          "cited_by": { "type": ["string", "null"], "description": "Notable citations" },
          "tags": { "type": "array", "items": { "type": "string" } }
        },
        "required": ["title", "venue", "date"]
      }
    }
  },
  "required": ["identity", "experience", "skills", "education"]
}
